# Database Configuration
# SQLite (development):
# DATABASE_URL=sqlite+aiosqlite:///./textbook_qa.db
# MySQL (production):
DATABASE_URL=mysql+aiomysql://root:SKBelekar2736@localhost:3306/textbook_qa

# Authentication & JWT
SECRET_KEY=change-me-in-production-use-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cerebras Configuration (LLM Provider)
CEREBRAS_API_KEY=your-cerebras-api-key-here

# Pinecone Configuration (Vector Database)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=textbook-qa

# Embeddings Configuration
# Options: "openai" (requires OPENAI_API_KEY) or "local" (requires sentence-transformers)
# Default: "openai"
EMBEDDING_PROVIDER=openai

# OpenAI Configuration (for embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# FastAPI Configuration
API_TITLE=Textbook Q&A RAG
API_VERSION=0.1.0
DEBUG=False
